  color: #fca5a5;
}

.triage-choice-card.kuning span {
  color: #fcd34d;
}

.triage-choice-card.hijau span {
  color: #86efac;
}

.triage-choice-card.merah.selected {
  border-color: rgba(239, 68, 68, 0.42);
  background: rgba(239, 68, 68, 0.14);
}

.triage-choice-card.kuning.selected {
  border-color: rgba(245, 158, 11, 0.42);
  background: rgba(245, 158, 11, 0.14);
}

.triage-choice-card.hijau.selected {
  border-color: rgba(34, 197, 94, 0.42);
  background: rgba(34, 197, 94, 0.14);
}

.triage-summary-card {
  margin-top: 22px;
  padding: 22px;
  border-radius: 24px;
  border: 1px solid rgba(148, 163, 184, 0.18);
}

.triage-summary-card small {
  color: #7dd3fc;
  font-size: 13px;
  font-weight: 900;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.triage-summary-card strong {
  display: block;
