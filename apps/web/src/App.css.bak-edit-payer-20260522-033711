  align-content: space-between;
  text-align: left;
  cursor: pointer;
  transition:
    transform 180ms ease,
    border-color 180ms ease,
    background 180ms ease;
}

.triage-choice-card:hover {
  transform: translateY(-2px);
}

.triage-choice-card span {
  font-size: 16px;
  font-weight: 900;
}

.triage-choice-card strong {
  color: #f8fafc;
