  gap: 22px;
}

.emergency-assessment-main,
.emergency-assessment-summary {
  display: grid;
  align-content: start;
  gap: 22px;
}

.triage-choice-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16px;
}

.triage-choice-card {
  min-height: 142px;
  padding: 22px;
  border-radius: 24px;
  border: 1px solid rgba(148, 163, 184, 0.18);
