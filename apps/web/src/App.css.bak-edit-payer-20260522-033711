/* Edit patient registration modal */
.registration-action-row {
  display: flex;
  align-items: center;
  gap: 10px;
}

.edit-registration-button {
  min-width: 76px;
  border: 1px solid rgba(245, 158, 11, 0.45);
  border-radius: 14px;
  background: rgba(245, 158, 11, 0.12);
  color: #facc15;
  font-size: 14px;
  line-height: 1.2;
  padding: 10px 16px;
  cursor: pointer;
}

.edit-registration-button:hover {
  background: rgba(245, 158, 11, 0.2);
}

.registration-edit-modal-backdrop {
  position: fixed;
  inset: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24px;
  background: rgba(2, 6, 23, 0.72);
  backdrop-filter: blur(8px);
}

.registration-edit-modal {
  width: min(860px, 100%);
  max-height: 92vh;
  overflow-y: auto;
  border: 1px solid rgba(148, 163, 184, 0.24);
  border-radius: 28px;
  background: #0f172a;
  box-shadow: 0 24px 80px rgba(0, 0, 0, 0.45);
  padding: 28px;
}

.registration-edit-modal-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24px;
  margin-bottom: 24px;
}

.registration-edit-modal-header small {
  display: block;
  color: #7dd3fc;
  font-size: 13px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  margin-bottom: 8px;
}

.registration-edit-modal-header h2 {
  margin: 0;
  color: #f8fafc;
  font-size: 28px;
}

.registration-edit-modal-header p {
  margin: 8px 0 0;
  color: #94a3b8;
  font-size: 15px;
  line-height: 1.6;
}

.registration-edit-modal-header button {
  width: 38px;
  height: 38px;
  border: 1px solid rgba(148, 163, 184, 0.28);
  border-radius: 999px;
  background: rgba(15, 23, 42, 0.8);
  color: #cbd5e1;
  font-size: 24px;
  cursor: pointer;
}

.registration-edit-form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18px;
}

.registration-edit-form-grid label {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.registration-edit-form-grid span {
  color: #cbd5e1;
  font-size: 14px;
}

.registration-edit-form-grid input,
.registration-edit-form-grid select {
  width: 100%;
  border: 1px solid rgba(148, 163, 184, 0.28);
  border-radius: 16px;
  background: #020617;
  color: #e2e8f0;
  font-size: 15px;
  padding: 14px 16px;
  outline: none;
}

.registration-edit-form-grid input:focus,
.registration-edit-form-grid select:focus {
  border-color: rgba(56, 189, 248, 0.8);
  box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.12);
}

.registration-edit-form-grid input:disabled {
  color: #94a3b8;
  background: rgba(15, 23, 42, 0.8);
  cursor: not-allowed;
}

.registration-edit-modal-footer {
  display: flex;
  justify-content: flex-end;
  gap: 12px;
  margin-top: 28px;
}

.registration-edit-modal-footer button {
  border-radius: 16px;
  padding: 13px 20px;
  font-weight: 700;
  cursor: pointer;
}

.registration-edit-modal-footer button:first-child {
  border: 1px solid rgba(148, 163, 184, 0.28);
  background: transparent;
  color: #cbd5e1;
}

.registration-edit-modal-footer button:last-child {
  border: 1px solid rgba(245, 158, 11, 0.55);
  background: #f59e0b;
  color: #111827;
}

.registration-edit-modal-footer button:last-child:hover {
  background: #fbbf24;
}

@media (max-width: 768px) {
  .registration-action-row {
    flex-direction: column;
    align-items: stretch;
  }

  .registration-edit-form-grid {
    grid-template-columns: 1fr;
  }

  .registration-edit-modal {
    padding: 22px;
  }
}
