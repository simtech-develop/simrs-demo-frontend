.simrs-page {
  min-height: 100vh;
  padding: 48px;
  background:
    radial-gradient(circle at top left, rgba(0, 188, 212, 0.14), transparent 32%),
    radial-gradient(circle at top right, rgba(59, 130, 246, 0.16), transparent 28%),
    #08111f;
  color: #e5eefb;
}

.hero {
  max-width: 1380px;
  margin: 0 auto 32px;
  display: grid;
  grid-template-columns: minmax(0, 1.05fr) minmax(420px, 0.95fr);
  gap: 36px;
  align-items: stretch;
}

.hero-copy,
.hero-panel,
.section-card {
  border: 1px solid rgba(148, 163, 184, 0.18);
  background: rgba(15, 23, 42, 0.78);
  backdrop-filter: blur(18px);
  box-shadow: 0 24px 80px rgba(2, 6, 23, 0.32);
  border-radius: 32px;
}

.hero-copy {
  padding: 48px;
}

.badge {
  display: inline-flex;
  align-items: center;
  min-height: 36px;
  padding: 0 16px;
  border-radius: 999px;
  border: 1px solid rgba(56, 189, 248, 0.3);
  background: rgba(14, 165, 233, 0.12);
  color: #7dd3fc;
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 0.03em;
}

.hero h1 {
  max-width: 850px;
  margin: 28px 0 20px;
  font-size: clamp(44px, 5vw, 74px);
  line-height: 0.98;
  letter-spacing: -0.05em;
  color: #f8fbff;
}

.hero h1 span {
  display: block;
  color: #38bdf8;
}

.hero-description {
  max-width: 780px;
  margin: 0;
  color: #cbd5e1;
  font-size: 18px;
  line-height: 1.8;
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  margin-top: 34px;
}

.primary-button,
.secondary-button {
  min-height: 54px;
  padding: 0 24px;
  border-radius: 18px;
  font-size: 15px;
  font-weight: 800;
  cursor: pointer;
  transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
}

.primary-button {
  border: 0;
  background: linear-gradient(135deg, #0ea5e9, #2563eb);
  color: white;
  box-shadow: 0 16px 34px rgba(14, 165, 233, 0.28);
}

.secondary-button {
  border: 1px solid rgba(148, 163, 184, 0.24);
  background: rgba(15, 23, 42, 0.88);
  color: #e2e8f0;
}

.primary-button:hover,
.secondary-button:hover {
  transform: translateY(-2px);
}

.hero-metrics {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16px;
  margin-top: 42px;
}

.hero-metrics div,
.queue-grid div {
  border-radius: 22px;
  border: 1px solid rgba(148, 163, 184, 0.16);
  background: rgba(15, 23, 42, 0.82);
}

.hero-metrics div {
  padding: 20px;
}

.hero-metrics strong {
  display: block;
  margin-bottom: 8px;
  color: #f8fafc;
  font-size: 28px;
}

.hero-metrics span {
  color: #94a3b8;
  font-size: 14px;
}

.hero-panel {
  padding: 28px;
  display: grid;
  gap: 22px;
}

.panel-header {
  display: flex;
  align-items: center;
  gap: 12px;
  color: #cbd5e1;
  font-weight: 700;
}

.panel-header p {
  margin: 0;
}

.status-dot {
  width: 12px;
  height: 12px;
  border-radius: 999px;
  background: #22c55e;
  box-shadow: 0 0 22px rgba(34, 197, 94, 0.8);
}

.hospital-card {
  padding: 28px;
  border-radius: 28px;
  background:
    linear-gradient(145deg, rgba(14, 165, 233, 0.17), rgba(15, 23, 42, 0.76)),
    rgba(15, 23, 42, 0.92);
  border: 1px solid rgba(56, 189, 248, 0.22);
}

.hospital-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16px;
  margin-bottom: 26px;
}

.hospital-top small,
.next-step small {
  display: block;
  margin-bottom: 8px;
  color: #7dd3fc;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  font-weight: 800;
}

.hospital-top h2 {
  margin: 0;
  color: #f8fafc;
  font-size: 28px;
}

.active-pill {
  padding: 10px 14px;
  border-radius: 999px;
  background: rgba(34, 197, 94, 0.14);
  color: #86efac;
  border: 1px solid rgba(34, 197, 94, 0.24);
  font-size: 13px;
  font-weight: 800;
}

.queue-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}

.queue-grid div {
  padding: 18px;
}

.queue-grid span {
  display: block;
  margin-bottom: 10px;
  color: #94a3b8;
  font-size: 14px;
}

.queue-grid strong {
  color: #f8fafc;
  font-size: 34px;
}

.timeline {
  display: grid;
  gap: 14px;
}

.timeline div {
  display: grid;
  grid-template-columns: 14px minmax(0, 1fr) auto;
  gap: 14px;
  align-items: center;
  padding: 18px;
  border-radius: 22px;
  background: rgba(15, 23, 42, 0.72);
  border: 1px solid rgba(148, 163, 184, 0.14);
}

.timeline div span {
  width: 12px;
  height: 12px;
  border-radius: 999px;
  background: #38bdf8;
}

.timeline p {
  margin: 0;
  color: #dbeafe;
  font-weight: 700;
}

.timeline strong {
  color: #7dd3fc;
  font-size: 14px;
}

.content-grid {
  max-width: 1380px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: minmax(0, 1.45fr) minmax(360px, 0.55fr);
  gap: 32px;
}

.section-card {
  padding: 34px;
}

.section-heading p {
  margin: 0 0 8px;
  color: #7dd3fc;
  font-size: 14px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.section-heading h2 {
  margin: 0 0 28px;
  color: #f8fafc;
  font-size: 34px;
  letter-spacing: -0.03em;
}

.module-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18px;
}

.module-card {
  min-height: 178px;
  padding: 24px;
  border-radius: 24px;
  border: 1px solid rgba(148, 163, 184, 0.16);
  background: rgba(15, 23, 42, 0.76);
}

.module-card h3 {
  margin: 0 0 14px;
  color: #f8fafc;
  font-size: 21px;
}

.module-card p {
  margin: 0;
  color: #cbd5e1;
  line-height: 1.7;
  font-size: 15px;
}

.principle-section ul {
  margin: 0;
  padding: 0;
  list-style: none;
  display: grid;
  gap: 16px;
}

.principle-section li {
  position: relative;
  padding: 18px 18px 18px 48px;
  border-radius: 20px;
  border: 1px solid rgba(148, 163, 184, 0.16);
  background: rgba(15, 23, 42, 0.76);
  color: #dbeafe;
  line-height: 1.6;
}

.principle-section li::before {
  content: '✓';
  position: absolute;
  left: 18px;
  top: 17px;
  width: 20px;
  height: 20px;
  border-radius: 999px;
  display: grid;
  place-items: center;
  background: rgba(34, 197, 94, 0.16);
  color: #86efac;
  font-size: 13px;
  font-weight: 900;
}

.next-step {
  margin-top: 24px;
  padding: 24px;
  border-radius: 24px;
  border: 1px solid rgba(56, 189, 248, 0.2);
  background: rgba(14, 165, 233, 0.12);
}

.next-step strong {
  display: block;
  color: #f8fafc;
  font-size: 20px;
  line-height: 1.5;
}

@media (max-width: 1180px) {
  .hero,
  .content-grid {
    grid-template-columns: 1fr;
  }

  .module-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 820px) {
  .simrs-page {
    padding: 22px;
  }

  .hero-copy,
  .hero-panel,
  .section-card {
    padding: 24px;
    border-radius: 24px;
  }

  .hero h1 {
    font-size: 42px;
  }

  .hero-metrics,
  .module-grid,
  .queue-grid {
    grid-template-columns: 1fr;
  }

  .timeline div {
    grid-template-columns: 14px 1fr;
  }

  .timeline strong {
    grid-column: 2;
  }
}

.primary-link {
  min-height: 54px;
  padding: 0 24px;
  border-radius: 18px;
  border: 0;
  background: linear-gradient(135deg, #0ea5e9, #2563eb);
  color: white;
  box-shadow: 0 16px 34px rgba(14, 165, 233, 0.28);
  font-size: 15px;
  font-weight: 800;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: transform 180ms ease;
}

.primary-link:hover {
  transform: translateY(-2px);
}

.simple-page {
  min-height: 100vh;
  display: grid;
  place-items: center;
  padding: 32px;
  background: #08111f;
  color: #e5eefb;
}

.simple-card {
  width: min(760px, 100%);
  padding: 42px;
  border-radius: 32px;
  border: 1px solid rgba(148, 163, 184, 0.18);
  background: rgba(15, 23, 42, 0.86);
}

.simple-eyebrow {
  margin: 0 0 12px;
  color: #7dd3fc;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.simple-card h1 {
  margin: 0 0 18px;
  color: #f8fafc;
  font-size: 48px;
  letter-spacing: -0.04em;
}

.simple-card p {
  color: #cbd5e1;
  font-size: 18px;
  line-height: 1.8;
}

.simple-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  margin-top: 28px;
}

.simple-actions button,
.simple-actions a {
  min-height: 52px;
  padding: 0 20px;
  border-radius: 16px;
  border: 1px solid rgba(148, 163, 184, 0.18);
  background: rgba(14, 165, 233, 0.14);
  color: #f8fafc;
  font-weight: 800;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.login-page {
  min-height: 100vh;
  display: grid;
  grid-template-columns: minmax(0, 1.05fr) minmax(440px, 0.95fr);
  gap: 32px;
  padding: 38px;
  background:
    radial-gradient(circle at top left, rgba(14, 165, 233, 0.18), transparent 32%),
    radial-gradient(circle at bottom right, rgba(37, 99, 235, 0.18), transparent 34%),
    #08111f;
  color: #e5eefb;
}

.login-showcase,
.login-form-area {
  border: 1px solid rgba(148, 163, 184, 0.18);
  background: rgba(15, 23, 42, 0.82);
  backdrop-filter: blur(18px);
  box-shadow: 0 24px 80px rgba(2, 6, 23, 0.28);
  border-radius: 34px;
}

.login-showcase {
  padding: 42px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 32px;
}

.login-back-link {
  width: fit-content;
  color: #93c5fd;
  text-decoration: none;
  font-weight: 800;
  transition: opacity 180ms ease;
}

.login-back-link:hover {
  opacity: 0.8;
}

.login-brand-badge {
  display: inline-flex;
  width: fit-content;
  min-height: 38px;
  align-items: center;
  padding: 0 16px;
  border-radius: 999px;
  border: 1px solid rgba(56, 189, 248, 0.3);
  background: rgba(14, 165, 233, 0.12);
  color: #7dd3fc;
  font-size: 14px;
  font-weight: 900;
  letter-spacing: 0.04em;
}

.login-brand-block h1 {
  margin: 28px 0 18px;
  max-width: 780px;
  color: #f8fafc;
  font-size: clamp(48px, 5.2vw, 76px);
  line-height: 0.98;
  letter-spacing: -0.055em;
}

.login-brand-block h1 strong {
  display: block;
  color: #38bdf8;
}

.login-brand-block p {
  max-width: 760px;
  margin: 0;
  color: #cbd5e1;
  font-size: 18px;
  line-height: 1.82;
}

.login-highlight-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18px;
}

.login-highlight-grid article,
.login-role-panel,
.login-card-pro,
.demo-account-note {
  border: 1px solid rgba(148, 163, 184, 0.16);
  background: rgba(2, 6, 23, 0.28);
}

.login-highlight-grid article {
  min-height: 180px;
  padding: 24px;
  border-radius: 26px;
}

.login-highlight-grid small,
.login-role-panel small,
.login-card-pro header small {
  display: block;
  margin-bottom: 10px;
  color: #7dd3fc;
  font-size: 13px;
  font-weight: 900;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.login-highlight-grid strong {
  display: block;
  margin-bottom: 12px;
  color: #f8fafc;
  font-size: 24px;
  line-height: 1.35;
}

.login-highlight-grid span {
  color: #cbd5e1;
  line-height: 1.7;
}

.login-role-panel {
  padding: 24px;
  border-radius: 26px;
}

.login-role-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.login-role-list span {
  padding: 12px 16px;
  border-radius: 999px;
  border: 1px solid rgba(56, 189, 248, 0.18);
  background: rgba(14, 165, 233, 0.1);
  color: #dbeafe;
  font-weight: 800;
}

.login-form-area {
  padding: 32px;
  display: grid;
  place-items: center;
}

.login-card-pro {
  width: min(560px, 100%);
  padding: 34px;
  border-radius: 30px;
  background:
    linear-gradient(145deg, rgba(14, 165, 233, 0.08), rgba(2, 6, 23, 0.22)),
    rgba(15, 23, 42, 0.84);
}

.login-card-pro header h2 {
  margin: 0 0 14px;
  color: #f8fafc;
  font-size: 38px;
  line-height: 1.12;
  letter-spacing: -0.04em;
}

.login-card-pro header p {
  margin: 0;
  color: #cbd5e1;
  line-height: 1.75;
}

.login-form-pro {
  display: grid;
  gap: 18px;
  margin-top: 30px;
}

.login-form-pro label > span {
  display: block;
  margin-bottom: 10px;
  color: #e2e8f0;
  font-weight: 900;
}

.login-form-pro input[type="text"],
.login-form-pro input[type="password"] {
  width: 100%;
  height: 58px;
  padding: 0 18px;
  border-radius: 18px;
  border: 1px solid rgba(148, 163, 184, 0.22);
  background: rgba(2, 6, 23, 0.42);
  color: #f8fafc;
  outline: none;
  transition: border-color 180ms ease, box-shadow 180ms ease;
}

.login-form-pro input:focus {
  border-color: rgba(56, 189, 248, 0.72);
  box-shadow: 0 0 0 4px rgba(14, 165, 233, 0.12);
}

.login-form-options {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
  margin-top: 4px;
}

.login-checkbox {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  color: #cbd5e1;
}

.login-checkbox input {
  width: 18px;
  height: 18px;
}

.prototype-pill {
  display: inline-flex;
  align-items: center;
  min-height: 38px;
  padding: 0 14px;
  border-radius: 999px;
  border: 1px solid rgba(34, 197, 94, 0.24);
  background: rgba(34, 197, 94, 0.12);
  color: #86efac;
  font-size: 13px;
  font-weight: 900;
}

.login-form-pro button {
  min-height: 60px;
  margin-top: 6px;
  border: 0;
  border-radius: 18px;
  background: linear-gradient(135deg, #0ea5e9, #2563eb);
  color: #ffffff;
  box-shadow: 0 18px 40px rgba(14, 165, 233, 0.28);
  font-size: 16px;
  font-weight: 900;
  cursor: pointer;
  transition: transform 180ms ease;
}

.login-form-pro button:hover {
  transform: translateY(-2px);
}

.demo-account-note {
  display: grid;
  gap: 12px;
  margin-top: 24px;
  padding: 22px;
  border-radius: 24px;
}

.demo-account-note strong {
  color: #f8fafc;
  font-size: 17px;
}

.demo-account-note div {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  color: #cbd5e1;
}

.demo-account-note code {
  padding: 8px 12px;
  border-radius: 12px;
  background: rgba(15, 23, 42, 0.92);
  color: #7dd3fc;
  font-weight: 900;
}

.login-disclaimer {
  margin: 22px 0 0;
  color: #94a3b8;
  font-size: 14px;
  line-height: 1.75;
}

@media (max-width: 1180px) {
  .login-page {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 820px) {
  .login-page {
    padding: 20px;
  }

  .login-showcase,
  .login-form-area {
    padding: 24px;
    border-radius: 26px;
  }

  .login-card-pro {
    padding: 24px;
  }

  .login-highlight-grid {
    grid-template-columns: 1fr;
  }

  .login-form-options,
  .demo-account-note div {
    flex-direction: column;
    align-items: flex-start;
  }
}

.dashboard-app {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 308px minmax(0, 1fr);
  background:
    radial-gradient(circle at top right, rgba(37, 99, 235, 0.18), transparent 30%),
    radial-gradient(circle at bottom left, rgba(14, 165, 233, 0.12), transparent 34%),
    #08111f;
  color: #e5eefb;
}

.dashboard-sidebar-pro {
  min-height: 100vh;
  padding: 30px 22px;
  display: flex;
  flex-direction: column;
  border-right: 1px solid rgba(148, 163, 184, 0.16);
  background: rgba(6, 15, 28, 0.96);
}

.sidebar-brand-pro span,
.sidebar-brand-pro strong,
.sidebar-brand-pro p {
  display: block;
}

.sidebar-brand-pro span {
  color: #7dd3fc;
  font-size: 14px;
  font-weight: 900;
  letter-spacing: 0.14em;
}

.sidebar-brand-pro strong {
  margin-top: 4px;
  color: #f8fafc;
  font-size: 34px;
  line-height: 1.1;
  letter-spacing: -0.04em;
}

.sidebar-brand-pro p {
  margin: 8px 0 0;
  color: #94a3b8;
  font-size: 14px;
}

.sidebar-menu-pro {
  display: grid;
  gap: 10px;
  margin-top: 40px;
}

.sidebar-menu-pro a {
  min-height: 52px;
  display: flex;
  align-items: center;
  padding: 0 18px;
  border-radius: 18px;
