  gap: 8px;
}

.sidebar-demo-card small {
  color: #7dd3fc;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.sidebar-demo-card strong {
  color: #f8fafc;
  font-size: 18px;
}

.sidebar-demo-card span {
  color: #94a3b8;
  line-height: 1.6;
}

.sidebar-demo-card a {
  margin-top: 8px;
  color: #93c5fd;
  font-weight: 900;
  text-decoration: none;
}

.dashboard-content-pro {
  padding: 38px;
}

.dashboard-header-pro {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 28px;
  margin-bottom: 28px;
}

.dashboard-header-pro small,
.dashboard-panel-title small {
  color: #7dd3fc;
  font-size: 13px;
  font-weight: 900;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.dashboard-header-pro h1 {
  margin: 10px 0 12px;
  color: #f8fafc;
  font-size: clamp(38px, 4vw, 56px);
  line-height: 1.05;
  letter-spacing: -0.05em;
}

.dashboard-header-pro p {
  max-width: 900px;
  margin: 0;
  color: #cbd5e1;
  font-size: 17px;
  line-height: 1.8;
}

.operator-profile-card,
.summary-card-pro,
.dashboard-panel-pro {
  border: 1px solid rgba(148, 163, 184, 0.18);
  background: rgba(15, 23, 42, 0.82);
  backdrop-filter: blur(18px);
  box-shadow: 0 24px 80px rgba(2, 6, 23, 0.22);
}

.operator-profile-card {
  min-width: 250px;
  padding: 22px;
  border-radius: 24px;
}

.operator-profile-card span,
.operator-profile-card strong,
.operator-profile-card p {
  display: block;
}

.operator-profile-card span {
  color: #94a3b8;
  margin-bottom: 8px;
}

.operator-profile-card strong {
  color: #f8fafc;
  font-size: 22px;
}

.operator-profile-card p {
  margin: 8px 0 0;
  color: #7dd3fc;
  font-weight: 900;
}

.dashboard-summary-grid {
  display: grid;
