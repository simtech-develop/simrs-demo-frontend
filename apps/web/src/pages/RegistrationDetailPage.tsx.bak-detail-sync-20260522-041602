import { useEffect, useState } from 'react'
import { Link, useParams } from 'react-router'
import { api } from '../lib/api'

const REGISTRATION_EDIT_STORAGE_KEY = 'simrs_registration_edit_overrides'

type RegistrationEditOverride = {
  id: string
  rm: string
  patient: string
  nik: string
  service: string
  doctor?: string
  type: string
  payerType?: 'Umum' | 'BPJS' | 'Asuransi'
  insuranceNo?: string
  phone?: string
  address?: string
  gender?: 'Laki-laki' | 'Perempuan' | '-'
  birthDate?: string
  queue: string
  status: 'Menunggu' | 'Terverifikasi' | 'Dilayani' | 'Dibatalkan'
}

const getRegistrationEditOverride = (
  registrationId?: string,
): RegistrationEditOverride | null => {
  if (!registrationId) {
    return null
  }

  try {
    const currentValue = window.localStorage.getItem(
      REGISTRATION_EDIT_STORAGE_KEY,
    )

    if (!currentValue) {
      return null
    }

    const currentOverrides = JSON.parse(currentValue) as Record<
      string,
      RegistrationEditOverride
    >

    return currentOverrides[registrationId] ?? null
  } catch (error) {
    console.error('Gagal membaca override edit registrasi:', error)
    return null
  }
}

const formatDisplayDate = (value?: string) => {
  if (!value || value === '-') {
    return '-'
  }

  const parts = value.split('-')

  if (parts.length !== 3) {
    return value
  }

  return `${parts[2]}/${parts[1]}/${parts[0]}`
}


type ApiRegistrationStatus =
  | 'WAITING'
  | 'IN_SERVICE'
  | 'COMPLETED'
  | 'CANCELED'

type UiRegistrationStatus =
  | 'Menunggu'
  | 'Terverifikasi'
  | 'Dilayani'
  | 'Dibatalkan'

type ApiRegistration = {
  id: string
  registrationNo: string
  visitDate: string
  queueNumber: number
  chiefComplaint?: string | null
  status: ApiRegistrationStatus
  createdAt: string
  updatedAt: string
  patient: {
    id: string
    medicalRecordNo: string
    nationalId?: string | null
    fullName: string
    gender?: 'MALE' | 'FEMALE'
    birthDate?: string | null
    phone?: string | null
    address?: string | null
  }
  clinic: {
    id: string
    code: string
    name: string
  }
  doctor?: {
    id: string
    fullName: string
  } | null
}

type RegistrationDetail = {
  id: string
  registrationNo: string
  rm: string
  nik: string
  patient: string
  gender: string
  birthDate: string
  phone: string
  address: string
  service: string
  queue: string
  status: UiRegistrationStatus
  initialComplaint: string
  doctorName: string
  visitDate: string
}

function displayValue(value?: string | null) {
  return value && value.trim() !== '' ? value : '-'
}

function mapGender(gender?: 'MALE' | 'FEMALE') {
  if (gender === 'MALE') {
    return 'Laki-laki'
  }

  if (gender === 'FEMALE') {
    return 'Perempuan'
  }

  return '-'
}

function mapStatus(status: ApiRegistrationStatus): UiRegistrationStatus {
  switch (status) {
    case 'WAITING':
      return 'Menunggu'
    case 'IN_SERVICE':
      return 'Terverifikasi'
    case 'COMPLETED':
      return 'Dilayani'
    case 'CANCELED':
      return 'Dibatalkan'
    default:
      return 'Menunggu'
  }
}

function mapUiStatusToApi(status: UiRegistrationStatus): ApiRegistrationStatus {
  switch (status) {
    case 'Menunggu':
      return 'WAITING'
    case 'Terverifikasi':
      return 'IN_SERVICE'
    case 'Dilayani':
      return 'COMPLETED'
    case 'Dibatalkan':
      return 'CANCELED'
    default:
      return 'WAITING'
  }
}

function formatDate(value?: string | null) {
  if (!value) {
    return '-'
  }

  const date = new Date(value)

  if (Number.isNaN(date.getTime())) {
    return '-'
  }

  return new Intl.DateTimeFormat('id-ID', {
    day: '2-digit',
    month: '2-digit',
    year: 'numeric',
  }).format(date)
}

function mapRegistration(item: ApiRegistration): RegistrationDetail {
  const queuePrefix = item.clinic.code || 'Q'

  return {
    id: item.id,
    registrationNo: item.registrationNo,
    rm: item.patient.medicalRecordNo,
    nik: item.patient.nationalId ?? '-',
    patient: item.patient.fullName,
    gender: mapGender(item.patient.gender),
    birthDate: formatDate(item.patient.birthDate),
    phone: item.patient.phone ?? '-',
    address: item.patient.address ?? '-',
    service: item.clinic.name,
    queue: `${queuePrefix}-${String(item.queueNumber).padStart(3, '0')}`,
    status: mapStatus(item.status),
    initialComplaint: item.chiefComplaint ?? '-',
    doctorName: item.doctor?.fullName ?? '-',
    visitDate: formatDate(item.visitDate),
  }
}

function RegistrationDetailPage() {
  const { id } = useParams()
  const [registration, setRegistration] =
    useState<RegistrationDetail | null>(null)
  const [isLoading, setIsLoading] = useState(true)
  const [isUpdating, setIsUpdating] = useState(false)
  const [loadError, setLoadError] = useState('')
  const [updateError, setUpdateError] = useState('')

  const loadRegistration = async () => {
    if (!id) {
      setLoadError('ID registrasi tidak tersedia.')
      setIsLoading(false)
      return
    }

    setIsLoading(true)
    setLoadError('')

    try {
      const response = await api.get<ApiRegistration>(`/registrations/${id}`)
      setRegistration(mapRegistration(response))
    } catch (error) {
      const message =
        error instanceof Error
          ? error.message
          : 'Gagal memuat detail registrasi dari backend.'

      setRegistration(null)
      setLoadError(message)
    } finally {
      setIsLoading(false)
    }
  }

  useEffect(() => {
    void loadRegistration()
  }, [id])

  const printTicket = () => {
    window.print()
  }

  const changeStatus = async (status: UiRegistrationStatus) => {
    if (!registration) {
      return
    }

    setIsUpdating(true)
    setUpdateError('')

    try {
      const response = await api.patch<
        ApiRegistration,
        { status: ApiRegistrationStatus }
      >(`/registrations/${registration.id}`, {
        status: mapUiStatusToApi(status),
      })

      setRegistration(mapRegistration(response))
    } catch (error) {
      const message =
        error instanceof Error
          ? error.message
          : 'Gagal memperbarui status registrasi.'

      setUpdateError(message)
    } finally {
      setIsUpdating(false)
    }
  }

  if (isLoading) {
    const editedRegistration = getRegistrationEditOverride(registration?.id)

  const displayDoctor =
    editedRegistration?.doctor && editedRegistration.doctor !== '-'
      ? editedRegistration.doctor
      : registration?.doctor?.fullName || '-'

  const displayPayerType =
    editedRegistration?.payerType === 'BPJS'
      ? 'BPJS Kesehatan'
      : editedRegistration?.payerType === 'Asuransi'
        ? 'Asuransi / Perusahaan'
        : editedRegistration?.payerType || 'Umum / Mandiri'

  const displayInsuranceNo =
    editedRegistration?.insuranceNo && editedRegistration.insuranceNo !== '-'
      ? editedRegistration.insuranceNo
      : '-'

  return (
      <main className="detail-not-found-page">
        <section className="detail-not-found-card">
          <small>Memuat Data</small>
          <h1>Detail registrasi sedang diproses</h1>
          <p>Mengambil data registrasi pasien dari backend SIMRS.</p>
        </section>
      </main>
    )
  }

  if (!registration) {
    return (
      <main className="detail-not-found-page">
        <section className="detail-not-found-card">
          <small>Data Tidak Ditemukan</small>
          <h1>Registrasi pasien tidak tersedia</h1>
          <p>
            {loadError ||
              'Data yang dipilih belum tersedia atau sudah tidak ada di backend.'}
          </p>
          <Link to="/pendaftaran">Kembali ke Modul Pendaftaran</Link>
        </section>
      </main>
    )
  }

  return (
    <main className="registration-detail-app">
      <aside className="dashboard-sidebar-pro">
        <div className="sidebar-brand-pro">
          <span>SIMRS</span>
          <strong>SIMTECH</strong>
          <p>Type D / C Demo Platform</p>
        </div>

        <nav className="sidebar-menu-pro">
          <Link to="/dashboard">Dashboard</Link>
          <Link className="active" to="/pendaftaran">
            Pendaftaran
          </Link>
          <Link to="/rawat-jalan">Rawat Jalan</Link>
          <Link to="/igd">IGD</Link>
          <Link to="/rme">RME</Link>
          <Link to="/farmasi">Farmasi</Link>
          <Link to="/kasir">Kasir</Link>
          <Link to="/laporan">Laporan</Link>
        </nav>

        <div className="sidebar-demo-card">
          <small>Demo Instance</small>
          <strong>RS SIMTECH Medika</strong>
          <span>Detail registrasi pasien</span>
          <Link to="/">Keluar dari Demo</Link>
        </div>
      </aside>

      <section className="registration-detail-content">
        <header className="registration-detail-header">
          <div className="registration-detail-heading">
            <Link className="breadcrumb-link" to="/pendaftaran">
              ← Kembali ke Daftar Pendaftaran
            </Link>

            <small>Detail Registrasi</small>
            <h1>{registration.patient}</h1>
            <p>
              Ringkasan data registrasi, antrean, dan tujuan layanan pasien yang
              telah tersimpan pada backend SIMRS Demo.
            </p>
          </div>

          <div className="registration-status-summary-card">
            <span>Status Pendaftaran</span>
            <strong>{registration.status}</strong>
            <p>{registration.queue}</p>
          </div>
        </header>

        {updateError && (
          <section className="registration-warning-banner">
            <strong>Status belum berhasil diperbarui.</strong>
            <span>{updateError}</span>
          </section>
        )}

        <section className="registration-ticket-banner">
          <div>
            <small>Bukti Registrasi</small>
            <strong>{registration.rm}</strong>
            <p>
              Nomor kunjungan <b>{registration.registrationNo}</b>. Antrean{' '}
              <b>{registration.queue}</b> untuk layanan{' '}
              <b>{registration.service}</b>.
            </p>
          </div>

          <button type="button" onClick={printTicket}>
            Cetak Bukti Antrean
          </button>
        </section>

        <section className="registration-action-panel">
          <div>
            <small>Workflow Registrasi</small>
            <h2>Perbarui Status Pelayanan</h2>
            <p>
              Ubah status registrasi untuk menunjukkan progres layanan dari
              antrean awal hingga pasien masuk tahap pelayanan.
            </p>
          </div>

          <div className="registration-action-buttons">
            <button
              type="button"
              disabled={isUpdating}
              className={
                registration.status === 'Terverifikasi'
                  ? 'active-action'
                  : ''
              }
              onClick={() => void changeStatus('Terverifikasi')}
            >
              Verifikasi Registrasi
            </button>

            <button
              type="button"
              disabled={isUpdating}
              className={
                registration.status === 'Dilayani'
                  ? 'active-action'
                  : ''
              }
              onClick={() => void changeStatus('Dilayani')}
            >
              Tandai Dilayani
            </button>

            <button
              type="button"
              disabled={isUpdating}
              className={
                registration.status === 'Menunggu'
                  ? 'active-action waiting-action'
                  : 'waiting-action'
              }
              onClick={() => void changeStatus('Menunggu')}
            >
              Kembalikan ke Menunggu
            </button>
          </div>
        </section>

        <section className="registration-detail-grid">
          <article className="detail-panel">
            <div className="detail-panel-title">
              <small>Identitas Pasien</small>
              <h2>Data Utama</h2>
            </div>

            <div className="detail-item-grid">
              <div>
                <span>No. Rekam Medis</span>
                <strong>{displayMedicalRecordNo}</strong>
              </div>
              <div>
                <span>NIK</span>
                <strong>{displayNationalId}</strong>
              </div>
              <div>
                <span>Nama Pasien</span>
                <strong>{displayPatientName}</strong>
              </div>
              <div>
                <span>Jenis Kelamin</span>
                <strong>{displayGender}</strong>
              </div>
              <div>
                <span>Tanggal Lahir</span>
                <strong>{displayBirthDate}</strong>
              </div>
              <div>
                <span>Nomor HP</span>
                <strong>{displayPhone}</strong>
              </div>
            </div>
          </article>

          <article className="detail-panel">
            <div className="detail-panel-title">
              <small>Administrasi</small>
              <h2>Kunjungan & Layanan</h2>
            </div>

            <div className="detail-item-grid">
              <div>
                <span>Nomor Registrasi</span>
                <strong>{registration.registrationNo}</strong>
              </div>
              <div>
                <span>Tanggal Kunjungan</span>
                <strong>{registration.visitDate}</strong>
              </div>
              <div>
                <span>Tujuan Layanan</span>
                <strong>{displayService}</strong>
              </div>
              <div>
                <span>Dokter</span>
                <strong>{displayDoctor}</strong>
              </div>

              <div>
                <span>Penjamin Pasien</span>
                <strong>{displayPayerType}</strong>
              </div>

              <div>
                <span>No. BPJS / Asuransi</span>
                <strong>{displayInsuranceNo}</strong>
              </div>
              <div>
                <span>Nomor Antrean</span>
                <strong>{displayQueue}</strong>
              </div>
              <div>
                <span>Status Registrasi</span>
                <strong>{displayStatus}</strong>
              </div>
            </div>
          </article>

          <article className="detail-panel wide-panel">
            <div className="detail-panel-title">
              <small>Kontak & Keterangan</small>
              <h2>Informasi Tambahan</h2>
            </div>

            <div className="detail-long-grid">
              <div>
                <span>Alamat</span>
                <strong>{displayAddress}</strong>
              </div>
              <div>
                <span>Keluhan Awal</span>
                <strong>{displayValue(registration.initialComplaint)}</strong>
              </div>
            </div>
          </article>
        </section>
      </section>
    </main>
  )
}

export default RegistrationDetailPage
